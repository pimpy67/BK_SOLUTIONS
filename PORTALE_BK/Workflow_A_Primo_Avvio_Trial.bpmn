      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Port_Recupera_di" bpmnElement="Activity_Port_Recupera">
        <dc:Bounds x="880" y="705" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Port_Crea_di" bpmnElement="Activity_Port_Crea">
        <dc:Bounds x="880" y="605" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Port_Dispositivo_di" bpmnElement="Activity_Port_Dispositivo">
