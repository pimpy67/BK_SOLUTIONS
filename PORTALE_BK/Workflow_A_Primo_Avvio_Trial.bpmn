      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Port_13_di" bpmnElement="Flow_Port_13">
        <di:waypoint x="250" y="1000"/>
        <di:waypoint x="967" y="1000"/>
      </bpmndi:BPMNEdge>

      <!-- Message flows -->
      <bpmndi:BPMNEdge id="MessageFlow_1_di" bpmnElement="MessageFlow_1">
        <di:waypoint x="430" y="368"/>
        <di:waypoint x="280" y="605"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="MessageFlow_2_di" bpmnElement="MessageFlow_2">
        <di:waypoint x="530" y="605"/>
        <di:waypoint x="580" y="368"/>
      </bpmndi:BPMNEdge>
