<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js" exporterVersion="14.0.0">
  <bpmn:collaboration id="Collaboration_1">
    <bpmn:participant id="Participant_Cliente" name="Cliente" processRef="Process_Cliente"/>
    <bpmn:participant id="Participant_Libreria" name="Libreria Client" processRef="Process_Libreria"/>
    <bpmn:participant id="Participant_Portale" name="Portale BK-Service" processRef="Process_Portale"/>
    <bpmn:messageFlow id="MessageFlow_1" sourceRef="Activity_Lib_Register" targetRef="Activity_Port_Valida"/>
    <bpmn:messageFlow id="MessageFlow_2" sourceRef="Activity_Port_Token" targetRef="Activity_Lib_Token"/>
    <bpmn:messageFlow id="MessageFlow_3" sourceRef="Activity_Lib_Issue" targetRef="Activity_Port_Issue"/>
    <bpmn:messageFlow id="MessageFlow_4" sourceRef="Activity_Port_Firma" targetRef="Activity_Lib_Ricevi"/>
  </bpmn:collaboration>

  <bpmn:process id="Process_Cliente" isExecutable="false">
    <bpmn:startEvent id="Event_Cliente_Start" name="Cliente scarica app da store">
      <bpmn:outgoing>Flow_Cliente_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_Cliente_Avvia" name="Avvia applicazione">
      <bpmn:incoming>Flow_Cliente_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Cliente_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Cliente_End" name="Trial disponibile">
      <bpmn:incoming>Flow_Cliente_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Cliente_1" sourceRef="Event_Cliente_Start" targetRef="Activity_Cliente_Avvia"/>
    <bpmn:sequenceFlow id="Flow_Cliente_2" sourceRef="Activity_Cliente_Avvia" targetRef="Event_Cliente_End"/>
  </bpmn:process>

  <bpmn:process id="Process_Libreria" isExecutable="false">
    <bpmn:startEvent id="Event_Lib_Start" name="App avviata">
      <bpmn:outgoing>Flow_Lib_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_Lib_Register" name="POST /client/register&#10;(paese, P.IVA, ragione_sociale,&#10;email, product_key)">
      <bpmn:incoming>Flow_Lib_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Lib_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Lib_Token" name="Ricevi registration_token">
      <bpmn:incoming>Flow_Lib_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Lib_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Lib_Issue" name="POST /client/license/issue&#10;(registration_token)">
      <bpmn:incoming>Flow_Lib_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Lib_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Lib_Ricevi" name="Ricevi entitlement firmato">
      <bpmn:incoming>Flow_Lib_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Lib_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Lib_Cache" name="Salva entitlement in cache locale">
      <bpmn:incoming>Flow_Lib_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Lib_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Lib_Sblocca" name="Sblocca funzioni trial nella UI">
      <bpmn:incoming>Flow_Lib_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Lib_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Lib_End" name="Trial pronta all'uso">
      <bpmn:incoming>Flow_Lib_8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Lib_1" sourceRef="Event_Lib_Start" targetRef="Activity_Lib_Register"/>
    <bpmn:sequenceFlow id="Flow_Lib_3" sourceRef="Activity_Lib_Register" targetRef="Activity_Lib_Token"/>
    <bpmn:sequenceFlow id="Flow_Lib_4" sourceRef="Activity_Lib_Token" targetRef="Activity_Lib_Issue"/>
    <bpmn:sequenceFlow id="Flow_Lib_5" sourceRef="Activity_Lib_Issue" targetRef="Activity_Lib_Ricevi"/>
    <bpmn:sequenceFlow id="Flow_Lib_6" sourceRef="Activity_Lib_Ricevi" targetRef="Activity_Lib_Cache"/>
    <bpmn:sequenceFlow id="Flow_Lib_7" sourceRef="Activity_Lib_Cache" targetRef="Activity_Lib_Sblocca"/>
    <bpmn:sequenceFlow id="Flow_Lib_8" sourceRef="Activity_Lib_Sblocca" targetRef="Event_Lib_End"/>
  </bpmn:process>

  <bpmn:process id="Process_Portale" isExecutable="true">
    <bpmn:startEvent id="Event_Port_Start" name="POST /register ricevuta">
      <bpmn:outgoing>Flow_Port_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_Port_Valida" name="Valida: P.IVA, ragione_sociale,&#10;email, product_key&#10;(trial già esistente per P.IVA?)">
      <bpmn:incoming>Flow_Port_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Port_1" name="Validazione OK?">
      <bpmn:incoming>Flow_Port_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_Port_Error</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_Port_Token" name="Genera registration_token a breve scadenza">
      <bpmn:incoming>Flow_Port_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Port_Error" name="Errore: Validazione fallita">
      <bpmn:incoming>Flow_Port_Error</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Activity_Port_Issue" name="POST /license/issue ricevuta">
      <bpmn:incoming>Flow_Port_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_Port_2" name="Trial già esiste per questo cliente?">
      <bpmn:incoming>Flow_Port_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_6</bpmn:outgoing>
      <bpmn:outgoing>Flow_Port_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_Port_Recupera" name="Recupera trial esistente da DB">
      <bpmn:incoming>Flow_Port_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Port_Crea" name="Crea nuova licenza TRIAL&#10;(status=TRIAL, data_scadenza da PianiCatalogo)">
      <bpmn:incoming>Flow_Port_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Port_Dispositivo" name="Registra dispositivo in tabella Dispositivi">
      <bpmn:incoming>Flow_Port_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Port_Firma" name="Firma entitlement con chiave privata del server">
      <bpmn:incoming>Flow_Port_9</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Port_Evento" name="Crea evento PORT_TRIAL_RILASCIATA">
      <bpmn:incoming>Flow_Port_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Port_Email" name="Invia email di benvenuto al fornitore">
      <bpmn:incoming>Flow_Port_11</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Port_Messaggio" name="Genera messaggio in-app per il cliente">
      <bpmn:incoming>Flow_Port_12</bpmn:incoming>
      <bpmn:outgoing>Flow_Port_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Port_End" name="Trial rilasciata con successo">
      <bpmn:incoming>Flow_Port_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Port_1" sourceRef="Event_Port_Start" targetRef="Activity_Port_Valida"/>
    <bpmn:sequenceFlow id="Flow_Port_2" sourceRef="Activity_Port_Valida" targetRef="Gateway_Port_1"/>
    <bpmn:sequenceFlow id="Flow_Port_3" sourceRef="Gateway_Port_1" targetRef="Activity_Port_Token" name="Sì"/>
    <bpmn:sequenceFlow id="Flow_Port_Error" sourceRef="Gateway_Port_1" targetRef="Event_Port_Error" name="No"/>
    <bpmn:sequenceFlow id="Flow_Port_4" sourceRef="Activity_Port_Token" targetRef="Activity_Port_Issue"/>
    <bpmn:sequenceFlow id="Flow_Port_5" sourceRef="Activity_Port_Issue" targetRef="Gateway_Port_2"/>
    <bpmn:sequenceFlow id="Flow_Port_6" sourceRef="Gateway_Port_2" targetRef="Activity_Port_Recupera" name="Sì"/>
    <bpmn:sequenceFlow id="Flow_Port_7" sourceRef="Gateway_Port_2" targetRef="Activity_Port_Crea" name="No"/>
    <bpmn:sequenceFlow id="Flow_Port_8" sourceRef="Activity_Port_Crea" targetRef="Activity_Port_Dispositivo"/>
    <bpmn:sequenceFlow id="Flow_Port_9" sourceRef="Activity_Port_Recupera" targetRef="Activity_Port_Firma"/>
    <bpmn:sequenceFlow id="Flow_Port_9a" sourceRef="Activity_Port_Dispositivo" targetRef="Activity_Port_Firma"/>
    <bpmn:sequenceFlow id="Flow_Port_10" sourceRef="Activity_Port_Firma" targetRef="Activity_Port_Evento"/>
    <bpmn:sequenceFlow id="Flow_Port_11" sourceRef="Activity_Port_Evento" targetRef="Activity_Port_Email"/>
    <bpmn:sequenceFlow id="Flow_Port_12" sourceRef="Activity_Port_Email" targetRef="Activity_Port_Messaggio"/>
    <bpmn:sequenceFlow id="Flow_Port_13" sourceRef="Activity_Port_Messaggio" targetRef="Event_Port_End"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collaboration_1">
