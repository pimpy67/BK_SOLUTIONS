<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_5" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js" exporterVersion="14.0.0">
  <bpmn:collaboration id="Collaboration_5">
    <bpmn:participant id="Participant_Libreria_E" name="Libreria Client" processRef="Process_Libreria_E"/>
    <bpmn:participant id="Participant_Portale_E" name="Portale BK-Service" processRef="Process_Portale_E"/>
  </bpmn:collaboration>

  <bpmn:process id="Process_Libreria_E" isExecutable="false">
    <bpmn:startEvent id="Event_Libreria_E_Start" name="Nuovo dispositivo tenta register">
      <bpmn:outgoing>Flow_Libreria_E_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_Genfingerprint_E" name="Genera fingerprint dispositivo">
      <bpmn:incoming>Flow_Libreria_E_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Libreria_E_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_PostRegister_E" name="POST /client/register">
      <bpmn:incoming>Flow_Libreria_E_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Libreria_E_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Heartbeat_E" name="Invia heartbeat periodico con session_id">
      <bpmn:incoming>Flow_Libreria_E_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Libreria_E_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Libreria_E_End" name="Monitoraggio attivo">
      <bpmn:incoming>Flow_Libreria_E_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Libreria_E_1" sourceRef="Event_Libreria_E_Start" targetRef="Activity_Genfingerprint_E"/>
    <bpmn:sequenceFlow id="Flow_Libreria_E_2" sourceRef="Activity_Genfingerprint_E" targetRef="Activity_PostRegister_E"/>
    <bpmn:sequenceFlow id="Flow_Libreria_E_3" sourceRef="Activity_PostRegister_E" targetRef="Activity_Heartbeat_E"/>
    <bpmn:sequenceFlow id="Flow_Libreria_E_4" sourceRef="Activity_Heartbeat_E" targetRef="Event_Libreria_E_End"/>
  </bpmn:process>

  <bpmn:process id="Process_Portale_E" isExecutable="true">
    <bpmn:startEvent id="Event_Portale_E_Start" name="POST /register ricevuta">
      <bpmn:outgoing>Flow_Portale_E_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Activity_Conta_Dispositivi" name="Conta dispositivi attivi per questa licenza">
      <bpmn:incoming>Flow_Portale_E_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_E_1" name="Supera max_dispositivi?">
      <bpmn:incoming>Flow_Portale_E_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_3</bpmn:outgoing>
      <bpmn:outgoing>Flow_Portale_E_4</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_Evento_Limite" name="Crea evento CLIENT_LIMITE_DISPOSITIVI">
      <bpmn:incoming>Flow_Portale_E_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Messaggio_Limite" name="Genera messaggio in-app: 'Limite dispositivi raggiunto'">
      <bpmn:incoming>Flow_Portale_E_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Salva_Dispositivo" name="OK: Salva nuovo dispositivo in DB">
      <bpmn:incoming>Flow_Portale_E_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Heartbeat_Monitor" name="Monitoraggio heartbeat: controlla session_id duplicate">
      <bpmn:incoming>Flow_Portale_E_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_E_2" name="Due session_id attivi sullo stesso fingerprint?">
      <bpmn:incoming>Flow_Portale_E_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_9</bpmn:outgoing>
      <bpmn:outgoing>Flow_Portale_E_10</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Activity_Evento_Manomissione" name="Crea evento CLIENT_MANOMISSIONE">
      <bpmn:incoming>Flow_Portale_E_9</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Email_Alert" name="Invia email ALERT al fornitore">
      <bpmn:incoming>Flow_Portale_E_11</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Activity_Nessuna_Frode" name="OK: Nessun comportamento sospetto">
      <bpmn:incoming>Flow_Portale_E_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Portale_E_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="Event_Portale_E_End" name="Monitoraggio completato">
      <bpmn:incoming>Flow_Portale_E_12</bpmn:incoming>
      <bpmn:incoming>Flow_Portale_E_13</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Portale_E_1" sourceRef="Event_Portale_E_Start" targetRef="Activity_Conta_Dispositivi"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_2" sourceRef="Activity_Conta_Dispositivi" targetRef="Gateway_E_1"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_3" sourceRef="Gateway_E_1" targetRef="Activity_Evento_Limite" name="Sì"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_4" sourceRef="Gateway_E_1" targetRef="Activity_Salva_Dispositivo" name="No"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_5" sourceRef="Activity_Evento_Limite" targetRef="Activity_Messaggio_Limite"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_6" sourceRef="Activity_Messaggio_Limite" targetRef="Event_Portale_E_End"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_7" sourceRef="Activity_Salva_Dispositivo" targetRef="Activity_Heartbeat_Monitor"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_8" sourceRef="Activity_Heartbeat_Monitor" targetRef="Gateway_E_2"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_9" sourceRef="Gateway_E_2" targetRef="Activity_Evento_Manomissione" name="Sì (Clonazione!)"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_10" sourceRef="Gateway_E_2" targetRef="Activity_Nessuna_Frode" name="No"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_11" sourceRef="Activity_Evento_Manomissione" targetRef="Activity_Email_Alert"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_12" sourceRef="Activity_Email_Alert" targetRef="Event_Portale_E_End"/>
    <bpmn:sequenceFlow id="Flow_Portale_E_13" sourceRef="Activity_Nessuna_Frode" targetRef="Event_Portale_E_End"/>
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_5">
    <bpmndi:BPMNPlane id="BPMNPlane_5" bpmnElement="Collaboration_5">
      <bpmndi:BPMNShape id="Participant_Libreria_E_di" bpmnElement="Participant_Libreria_E" isHorizontal="true">
        <dc:Bounds x="90" y="40" width="900" height="150"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Libreria_E_Start_di" bpmnElement="Event_Libreria_E_Start">
        <dc:Bounds x="150" y="100" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Genfingerprint_E_di" bpmnElement="Activity_Genfingerprint_E">
        <dc:Bounds x="240" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_PostRegister_E_di" bpmnElement="Activity_PostRegister_E">
        <dc:Bounds x="400" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Heartbeat_E_di" bpmnElement="Activity_Heartbeat_E">
        <dc:Bounds x="560" y="78" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Libreria_E_End_di" bpmnElement="Event_Libreria_E_End">
        <dc:Bounds x="720" y="100" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Libreria_E_1_di" bpmnElement="Flow_Libreria_E_1">
        <di:waypoint x="186" y="118"/>
        <di:waypoint x="240" y="118"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Libreria_E_2_di" bpmnElement="Flow_Libreria_E_2">
        <di:waypoint x="340" y="118"/>
        <di:waypoint x="400" y="118"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Libreria_E_3_di" bpmnElement="Flow_Libreria_E_3">
        <di:waypoint x="500" y="118"/>
        <di:waypoint x="560" y="118"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Libreria_E_4_di" bpmnElement="Flow_Libreria_E_4">
        <di:waypoint x="660" y="118"/>
        <di:waypoint x="720" y="118"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="Participant_Portale_E_di" bpmnElement="Participant_Portale_E" isHorizontal="true">
        <dc:Bounds x="90" y="240" width="900" height="600"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Portale_E_Start_di" bpmnElement="Event_Portale_E_Start">
        <dc:Bounds x="150" y="360" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Conta_Dispositivi_di" bpmnElement="Activity_Conta_Dispositivi">
        <dc:Bounds x="240" y="338" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_E_1_di" bpmnElement="Gateway_E_1" isMarkerVisible="true">
        <dc:Bounds x="405" y="353" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Evento_Limite_di" bpmnElement="Activity_Evento_Limite">
        <dc:Bounds x="520" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Messaggio_Limite_di" bpmnElement="Activity_Messaggio_Limite">
        <dc:Bounds x="680" y="260" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Salva_Dispositivo_di" bpmnElement="Activity_Salva_Dispositivo">
        <dc:Bounds x="520" y="450" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Heartbeat_Monitor_di" bpmnElement="Activity_Heartbeat_Monitor">
        <dc:Bounds x="680" y="450" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_E_2_di" bpmnElement="Gateway_E_2" isMarkerVisible="true">
        <dc:Bounds x="405" y="620" width="50" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Evento_Manomissione_di" bpmnElement="Activity_Evento_Manomissione">
        <dc:Bounds x="520" y="598" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Email_Alert_di" bpmnElement="Activity_Email_Alert">
        <dc:Bounds x="680" y="598" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_Nessuna_Frode_di" bpmnElement="Activity_Nessuna_Frode">
        <dc:Bounds x="230" y="620" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Portale_E_End_di" bpmnElement="Event_Portale_E_End">
        <dc:Bounds x="840" y="640" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_Portale_E_1_di" bpmnElement="Flow_Portale_E_1">
        <di:waypoint x="186" y="378"/>
        <di:waypoint x="240" y="378"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_2_di" bpmnElement="Flow_Portale_E_2">
        <di:waypoint x="340" y="378"/>
        <di:waypoint x="405" y="378"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_3_di" bpmnElement="Flow_Portale_E_3">
        <di:waypoint x="430" y="353"/>
        <di:waypoint x="570" y="340"/>
        <bpmndi:BPMNLabel><dc:Bounds x="445" y="335" width="20" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_4_di" bpmnElement="Flow_Portale_E_4">
        <di:waypoint x="430" y="403"/>
        <di:waypoint x="570" y="490"/>
        <bpmndi:BPMNLabel><dc:Bounds x="445" y="440" width="20" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_5_di" bpmnElement="Flow_Portale_E_5">
        <di:waypoint x="620" y="300"/>
        <di:waypoint x="680" y="300"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_6_di" bpmnElement="Flow_Portale_E_6">
        <di:waypoint x="780" y="300"/>
        <di:waypoint x="858" y="658"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_7_di" bpmnElement="Flow_Portale_E_7">
        <di:waypoint x="620" y="490"/>
        <di:waypoint x="680" y="490"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_8_di" bpmnElement="Flow_Portale_E_8">
        <di:waypoint x="730" y="530"/>
        <di:waypoint x="730" y="570"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_9_di" bpmnElement="Flow_Portale_E_9">
        <di:waypoint x="455" y="645"/>
        <di:waypoint x="520" y="638"/>
        <bpmndi:BPMNLabel><dc:Bounds x="435" y="627" width="45" height="27"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_10_di" bpmnElement="Flow_Portale_E_10">
        <di:waypoint x="405" y="645"/>
        <di:waypoint x="330" y="660"/>
        <bpmndi:BPMNLabel><dc:Bounds x="360" y="650" width="20" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_11_di" bpmnElement="Flow_Portale_E_11">
        <di:waypoint x="620" y="638"/>
        <di:waypoint x="680" y="638"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_12_di" bpmnElement="Flow_Portale_E_12">
        <di:waypoint x="780" y="638"/>
        <di:waypoint x="840" y="658"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Portale_E_13_di" bpmnElement="Flow_Portale_E_13">
        <di:waypoint x="280" y="700"/>
        <di:waypoint x="858" y="658"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>